{
  "name": "shopsmart-ai-backend",
  "version": "1.0.0",
  "description": "ShopSmart AI - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "predev": "npx kill-port 5000",
    "dev": "nodemon --exec ts-node src/server.ts",
    "seed:admin": "ts-node src/scripts/seedAdmin.ts",
    "seed:products": "ts-node src/scripts/seedProducts.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.5.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "cookie-parser": "^1.4.6",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.3.0",
    "stripe": "^16.2.0",
    "socket.io": "^4.7.5",
    "nodemailer": "^6.9.14",
    "zod": "^3.23.8",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "typescript": "5.5.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.7",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "eslint": "^9.7.0"
  }
}
